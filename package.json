{
  "name": "@oxyhq/sdk",
  "version": "1.0.0",
  "description": "OxyHQ SDK Monorepo \u2014 core, auth, services, and API packages",
  "private": true,
  "trustedDependencies": [
    "@shopify/react-native-skia",
    "better-sqlite3"
  ],
  "workspaces": [
    "packages/contracts",
    "packages/protocol",
    "packages/core",
    "packages/services",
    "packages/expo-splash",
    "packages/api",
    "packages/node",
    "packages/auth",
    "packages/accounts",
    "packages/commons",
    "packages/inbox",
    "packages/test-app-expo",
    "packages/console"
  ],
  "scripts": {
    "build:all": "turbo run build",
    "build:workspaces": "bun run build --filter '*'",
    "start": "cd packages/api && node dist/server.js",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "protocol:build": "bun run --filter @oxyhq/protocol build",
    "core:build": "bun run --filter @oxyhq/core build",
    "services:build": "bun run --filter @oxyhq/services build",
    "services:dev": "bun run --filter @oxyhq/services dev",
    "services:test": "bun run --filter @oxyhq/services test",
    "expo-splash:build": "bun run --filter @oxyhq/expo-splash build",
    "api:build": "bun run --filter @oxyhq/api build",
    "api:dev": "bun run --filter @oxyhq/api dev",
    "api:start": "bun run --filter @oxyhq/api start",
    "accounts:build": "bun run --filter accounts build",
    "accounts:dev": "bun run --filter accounts start",
    "accounts:start": "bun run --filter accounts start",
    "commons:dev": "bun run --filter commons start",
    "commons:start": "bun run --filter commons start",
    "inbox:build": "bun run --filter inbox build",
    "inbox:dev": "bun run --filter inbox start",
    "inbox:start": "bun run --filter inbox start",
    "console:dev": "bun run --filter oxy-console dev",
    "console:build": "bun run --filter oxy-console build"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.6",
    "@types/jest": "^30.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.11",
    "turbo": "^2.10.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=18.x"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxyhq/sdk.git"
  },
  "keywords": [
    "monorepo",
    "oxyhq",
    "sdk",
    "authentication",
    "api",
    "services"
  ],
  "author": "OxyHQ",
  "license": "MIT",
  "overrides": {
    "ioredis": "5.11.1",
    "send": "0.19.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@radix-ui/react-slot": "1.2.3",
    "@oxyhq/bloom": "^0.29.2",
    "markdown-it": "12.3.2"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@oxyhq/bloom": "^0.29.2",
    "expo-contacts": "~56.0.9",
    "expo-splash-screen": "~56.0.10",
    "is-arrayish": "^0.3.2",
    "react-native-worklets": "0.10.1"
  }
}
