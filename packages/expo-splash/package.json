{
  "name": "@oxyhq/expo-splash",
  "version": "0.1.0",
  "description": "Shared native-splash toolkit for Oxy Expo apps — each app centers its own logo on the shared dark brand background with the Oxy \"from Oxy\" symbol pinned to the bottom of the native OS splash (the \"Instagram, from Meta\" pattern).",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "source": "src/index.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "react-native": "./dist/esm/index.js",
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "default": "./dist/esm/index.js"
    },
    "./config": {
      "types": "./config/oxySplashScreenPlugin.d.ts",
      "default": "./config/oxySplashScreenPlugin.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./plugin/withOxySplashBranding": "./plugin/withOxySplashBranding.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "plugin",
    "config",
    "assets",
    "app.plugin.js"
  ],
  "keywords": [
    "oxyhq",
    "expo",
    "react-native",
    "splash-screen",
    "config-plugin",
    "branding"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oxyhq/sdk",
    "directory": "packages/expo-splash"
  },
  "author": "OxyHQ",
  "license": "AGPL-3.0-only",
  "homepage": "https://oxy.so",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "bun run build:cjs && bun run build:esm && bun run build:types",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && node scripts/fix-esm-imports.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rm -rf dist",
    "typescript": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "dependencies": {
    "@expo/image-utils": ">=0.7.0",
    "xml2js": "^0.6.2"
  },
  "peerDependencies": {
    "expo": ">=51.0.0",
    "expo-splash-screen": ">=0.27.0",
    "react": ">=18.0.0",
    "react-native": ">=0.74.0"
  },
  "devDependencies": {
    "@types/react": "*",
    "expo": "^57.0.6",
    "expo-splash-screen": "*",
    "react": "*",
    "react-native": "*",
    "typescript": "^5.9.2"
  }
}
