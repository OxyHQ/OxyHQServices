{
  "name": "@oxyhq/federation",
  "version": "0.4.1",
  "description": "Oxy Federation — the app-agnostic ActivityPub identity + follow engine substrate: the network-connector contract, normalized cross-network DTOs, HTTP signatures, actor resolution, the outbound delivery transport + follow lifecycle, the inbound dispatcher, and the webfinger/actor/inbox Express routers. Domain-parameterized so every Oxy app backend federates under its own domain.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "typesVersions": {
    "*": {
      "node": [
        "dist/types/node/index.d.ts"
      ]
    }
  },
  "source": "src/index.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "default": "./dist/esm/index.js"
    },
    "./node": {
      "import": {
        "types": "./dist/types/node/index.d.ts",
        "default": "./dist/esm/node/index.js"
      },
      "require": {
        "types": "./dist/types/node/index.d.ts",
        "default": "./dist/cjs/node/index.js"
      },
      "default": "./dist/esm/node/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "oxyhq",
    "federation",
    "activitypub",
    "webfinger",
    "fediverse",
    "connector"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OxyHQ/OxyHQServices",
    "directory": "packages/federation"
  },
  "author": "OxyHQ",
  "license": "AGPL-3.0-only",
  "homepage": "https://oxy.so",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "bun run --filter @oxyhq/contracts build && bun run --filter @oxyhq/protocol build && bun run --filter @oxyhq/core build && bun run build:cjs && bun run build:esm && bun run build:types",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json && node scripts/fix-esm-imports.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rm -rf dist",
    "typescript": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "lint": "biome lint --error-on-warnings ./src",
    "prepublishOnly": "bun run clean && bun run build",
    "release": "rm -rf dist && bun run build && release-it"
  },
  "release-it": {
    "git": {
      "tagName": "@oxyhq/federation@${version}",
      "tagAnnotation": "Release @oxyhq/federation@${version}",
      "commitMessage": "chore(federation): release @oxyhq/federation@${version}"
    },
    "github": {
      "release": true,
      "releaseName": "@oxyhq/federation@${version}"
    },
    "npm": {
      "publish": true
    }
  },
  "dependencies": {
    "@oxyhq/core": "workspace:^"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.1",
    "jest": "^29.7.0",
    "release-it": "^19.0.6",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.2"
  }
}
