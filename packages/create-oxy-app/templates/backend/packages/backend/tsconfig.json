{
  "extends": "@oxyhq/app-preset/tsconfig/backend.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@{{APP_SLUG}}/shared-types": ["../shared-types/src"],
      "@{{APP_SLUG}}/shared-types/*": ["../shared-types/src/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../shared-types" }]
}
