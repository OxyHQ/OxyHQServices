{
  "name": "@oxyhq/services",
  "version": "20.0.0",
  "description": "OxyHQ Expo/React Native SDK — UI components, screens, and native features",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/commonjs/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      },
      "default": "./lib/module/index.js"
    },
    "./ui": {
      "react-native": "./src/ui/index.ts",
      "import": {
        "types": "./lib/typescript/module/ui/index.d.ts",
        "default": "./lib/module/ui/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/ui/index.d.ts",
        "default": "./lib/commonjs/ui/index.js"
      },
      "default": "./lib/module/ui/index.js"
    },
    "./ui/client": {
      "react-native": "./src/ui/client.ts",
      "import": {
        "types": "./lib/typescript/module/ui/client.d.ts",
        "default": "./lib/module/ui/client.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/ui/client.d.ts",
        "default": "./lib/commonjs/ui/client.js"
      },
      "default": "./lib/module/ui/client.js"
    },
    "./ui/server": {
      "react-native": "./src/ui/server.ts",
      "import": {
        "types": "./lib/typescript/module/ui/server.d.ts",
        "default": "./lib/module/ui/server.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/ui/server.d.ts",
        "default": "./lib/commonjs/ui/server.js"
      },
      "default": "./lib/module/ui/server.js"
    },
    "./plugins/*": "./plugins/*.js",
    "./expo-module.config.json": "./expo-module.config.json",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "assets",
    "android/build.gradle",
    "android/src",
    "ios/OxyIdentityModule.swift",
    "ios/OxyIdentity.podspec",
    "plugins",
    "expo-module.config.json"
  ],
  "keywords": [
    "react-native",
    "expo",
    "ios",
    "android",
    "oxyhq",
    "sdk",
    "authentication",
    "ui-components"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oxyhq/sdk",
    "directory": "packages/services"
  },
  "author": "OxyHQ",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "homepage": "https://oxy.so",
  "scripts": {
    "typescript": "tsc --skipLibCheck --noEmit",
    "lint": "biome lint --error-on-warnings ./src",
    "build": "bun x react-native-builder-bob build --target commonjs && bun x react-native-builder-bob build --target module && bun x react-native-builder-bob build --target typescript && bun run copy-assets && bun run copy-dts && bun run delete-dts.js && bun run delete-debug-view",
    "build:js": "bun x react-native-builder-bob build --target commonjs && bun x react-native-builder-bob build --target module && bun run copy-assets",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "copy-assets": "copyfiles -u 1 \"src/assets/**/*\" lib/commonjs/assets && copyfiles -u 1 \"src/assets/**/*\" lib/module/assets",
    "copy-dts": "copyfiles -u 1 \"src/**/*.d.ts\" lib/typescript",
    "delete-debug-view": "rm -rf ./lib/commonjs/components/bottomSheetDebugView ./lib/module/components/bottomSheetDebugView ./lib/typescript/components/bottomSheetDebugView || true",
    "delete-dts.js": "find ./lib/commonjs -name '*.d.js*' -delete && find ./lib/module -name '*.d.js*' -delete",
    "release": "rm -rf lib && bun run build && release-it",
    "prepublishOnly": "bun run typescript && bun run test && bun run build"
  },
  "release-it": {
    "git": {
      "tagName": "@oxyhq/services@${version}",
      "tagAnnotation": "Release @oxyhq/services@${version}",
      "commitMessage": "chore(services): release @oxyhq/services@${version}"
    },
    "github": {
      "release": true,
      "releaseName": "@oxyhq/services@${version}"
    },
    "npm": {
      "publish": true
    }
  },
  "dependencies": {
    "@oxyhq/contracts": "workspace:*",
    "@oxyhq/core": "^10.0.0",
    "color": "^4.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^17.6.5",
    "@commitlint/config-conventional": "^17.6.5",
    "@oxyhq/core": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native/babel-preset": "^0.86.0",
    "@release-it/conventional-changelog": "^10.0.2",
    "@tanstack/query-async-storage-persister": "^5.101",
    "@tanstack/query-sync-storage-persister": "^5.101",
    "@tanstack/react-query": "^5.101",
    "@tanstack/react-query-persist-client": "^5.101",
    "@testing-library/jest-dom": "^6.4.2",
    "@types/color": "^4.2.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.9",
    "@types/react": "*",
    "copyfiles": "^2.4.1",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "husky": "^4.3.8",
    "jest": "~29.7.0",
    "lint-staged": "^15.2.4",
    "nativewind": "5.0.0-preview.3",
    "react-native-builder-bob": "^0.43.0",
    "react-native-css": "^3.0.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.22.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-reanimated": "4.5.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-svg": "15.15.5",
    "release-it": "^19.0.6",
    "socket.io-client": "^4.8.1",
    "ts-jest": "^29.4.0",
    "typescript": "^5.9.2",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@oxyhq/bloom": ">=0.16.0",
    "@oxyhq/core": "^10.0.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@tanstack/query-async-storage-persister": "^5.101",
    "@tanstack/query-sync-storage-persister": "^5.101",
    "@tanstack/react-query": "^5.101",
    "@tanstack/react-query-persist-client": "^5.101",
    "@types/react": "*",
    "@types/react-native": "*",
    "expo": ">=56.0.0",
    "expo-modules-core": "*",
    "expo-document-picker": ">=56.0.0",
    "expo-file-system": ">=56.0.0",
    "expo-font": ">=13.0.0",
    "expo-haptics": ">=56.0.0",
    "expo-image": ">=2.0.0",
    "expo-image-manipulator": ">=56.0.0",
    "expo-linear-gradient": ">=56.0.0",
    "nativewind": ">=5.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.85.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": ">=1.21.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-reanimated": ">=4.3.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-svg": ">=15.15.0",
    "socket.io-client": "^4.8.0",
    "zustand": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "nativewind": {
      "optional": true
    },
    "expo-modules-core": {
      "optional": true
    },
    "@expo/vector-icons": {
      "optional": true
    },
    "@types/react-native": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    },
    "react-native-keyboard-controller": {
      "optional": true
    },
    "react-native-qrcode-svg": {
      "optional": true
    },
    "expo": {
      "optional": true
    },
    "expo-haptics": {
      "optional": true
    },
    "expo-linear-gradient": {
      "optional": true
    },
    "expo-document-picker": {
      "optional": true
    },
    "expo-image-manipulator": {
      "optional": true
    },
    "@tanstack/query-sync-storage-persister": {
      "optional": true
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
