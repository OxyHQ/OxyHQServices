{
  "name": "@oxyhq/api",
  "version": "1.0.3",
  "description": "OxyHQ API server with authentication, user management, and real-time features",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "bun --watch src/server.ts",
    "build": "bun run --filter @oxyhq/contracts build && bun run --filter @oxyhq/protocol build && bun run --filter @oxyhq/core build && bun run --filter @oxyhq/federation build && tsc",
    "clean": "rm -rf dist",
    "migrate:locations": "bun run src/utils/migrateLocations.ts",
    "register:commons-clients": "bun run scripts/register-commons-clients.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "openapi:generate": "bun scripts/generate-openapi.ts",
    "prepublishOnly": "bun run clean && bun run build",
    "release": "rm -rf dist && bun run build && release-it"
  },
  "release-it": {
    "git": {
      "tagName": "@oxyhq/api@${version}",
      "tagAnnotation": "Release @oxyhq/api@${version}",
      "commitMessage": "chore(api): release @oxyhq/api@${version}"
    },
    "github": {
      "release": true,
      "releaseName": "@oxyhq/api@${version}"
    },
    "npm": {
      "publish": true
    }
  },
  "keywords": [
    "api",
    "express",
    "socket.io",
    "authentication",
    "mongoose",
    "oxyhq"
  ],
  "author": "OxyHQ",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "@aws-sdk/lib-storage": "3.1091.0",
    "@aws-sdk/s3-request-presigner": "^3.1091.0",
    "@oxyhq/contracts": "workspace:*",
    "@oxyhq/core": "workspace:*",
    "@oxyhq/federation": "workspace:*",
    "@oxyhq/protocol": "workspace:*",
    "@simplewebauthn/server": "13.3.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/cheerio": "^0.22.35",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/elliptic": "^6.4.18",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^8.0.1",
    "@types/smtp-server": "^3.5.13",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.18.1",
    "bullmq": "^5.80.9",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "elliptic": "^6.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.0",
    "express-slow-down": "^2.0.3",
    "gridfs-stream": "^1.1.1",
    "helmet": "^8.3.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.14",
    "mongoose": "^8.24.1",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.35.3",
    "smtp-server": "^3.19.2",
    "socket.io": "^4.8.1",
    "stripe": "^20.4.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.1",
    "zod": "^3.25.64"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0"
  },
  "devDependencies": {
    "@expo/code-signing-certificates": "0.0.6",
    "@types/express-slow-down": "^1.3.5",
    "@types/gridfs-stream": "^0.5.39",
    "@types/http-errors": "^2.0.4",
    "@types/mongodb": "^4.0.7",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.39.5",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "release-it": "^19.0.6",
    "socket.io-client": "^4.8.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.65.0"
  }
}
