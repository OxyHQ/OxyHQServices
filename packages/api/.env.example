# =============================================================================
# Oxy API — Environment Configuration (template)
# =============================================================================
# Copy this file to `.env` and fill in real values for local development.
# In production (AWS / containers) inject these via the orchestrator's secret
# store — NEVER commit a real `.env`.
#
# Legend:
#   [REQUIRED] — server refuses to boot without it (validateRequiredEnvVars)
#   [SECRET]   — sensitive; source from a secrets manager, never hardcode
#   [optional] — has a safe default or feature is disabled when unset
# =============================================================================


# -----------------------------------------------------------------------------
# Core — Database
# -----------------------------------------------------------------------------
# [REQUIRED] MongoDB connection string. Must start with mongodb:// or mongodb+srv://
# [SECRET]   (contains credentials in most deployments)
# The DB NAME is derived from NODE_ENV (oxy-prod / oxy-dev), not from this URI.
MONGODB_URI=mongodb://localhost:27017/oxy

# [optional] Mongoose connection-pool tuning (defaults shown)
# MONGO_MAX_POOL_SIZE=100
# MONGO_MIN_POOL_SIZE=10


# -----------------------------------------------------------------------------
# Core — Token secrets  (all [REQUIRED] + [SECRET])
# -----------------------------------------------------------------------------
# Generate strong values, e.g.:  openssl rand -base64 64
# In production each must be >= 32 chars and not a known placeholder, or boot fails.
# ACCESS_TOKEN_SECRET also signs/verifies Socket.IO auth and service tokens.
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# [optional] Legacy cross-domain SSO secret — no live route reads it after wave 2.
# Safe to omit in new deployments.
# SSO_INTERNAL_SECRET=


# -----------------------------------------------------------------------------
# Core — Object storage (S3 / S3-compatible)  ([REQUIRED] block)
# -----------------------------------------------------------------------------
# [REQUIRED]
AWS_REGION=us-east-1
# [REQUIRED] [SECRET]
AWS_ACCESS_KEY_ID=
# [REQUIRED] [SECRET]
AWS_SECRET_ACCESS_KEY=
# [REQUIRED] bucket name only (not a full path / URL)
AWS_S3_BUCKET=
# [optional] custom endpoint for S3-compatible stores (MinIO, DO Spaces, R2).
# Omit for real AWS S3.
# AWS_ENDPOINT_URL=https://your-s3-compatible-endpoint.com


# -----------------------------------------------------------------------------
# Server runtime
# -----------------------------------------------------------------------------
# [optional] Port the HTTP server binds (0.0.0.0). Code default is 3001, but the
# container image EXPOSEs 8080 — set PORT=8080 when running the Docker image.
PORT=8080
# [optional] development | production | test  (default: development)
NODE_ENV=production
# [optional] pino log level: trace|debug|info|warn|error  (default: info)
# LOG_LEVEL=info


# -----------------------------------------------------------------------------
# Redis / Valkey  ([optional] — falls back to in-memory if unset)
# -----------------------------------------------------------------------------
# Used for distributed rate limiting and the Socket.IO multi-instance adapter.
# [SECRET] (contains credentials). Use rediss:// for TLS.
# Omit for single-instance / local dev.
# REDIS_URL=rediss://default:password@valkey-host:6379


# -----------------------------------------------------------------------------
# Federation / ActivityPub  ([optional])
# -----------------------------------------------------------------------------
# Public domain this API is reachable at — used for actor/webfinger/nodeinfo
# and HTTP-Signature keyId. Default: oxy.so
# FEDERATION_DOMAIN=oxy.so
# Public domain of the Mention API (cross-service federation calls).
# MENTION_API_DOMAIN=mention.earth


# -----------------------------------------------------------------------------
# Stripe — billing / subscriptions  ([optional]; required to enable payments)
# -----------------------------------------------------------------------------
# [SECRET]
# STRIPE_SECRET_KEY=
# [SECRET] webhook signing secret for POST /billing/webhook
# STRIPE_WEBHOOK_SECRET=
# Price IDs for subscription tiers
# STRIPE_PRO_PRICE_ID=
# STRIPE_BUSINESS_PRICE_ID=


# -----------------------------------------------------------------------------
# Social / OAuth providers  ([optional]; per-provider sign-in)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=
# GITHUB_CLIENT_ID=
# [SECRET]
# GITHUB_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Redirect allow-list  ([optional])
# -----------------------------------------------------------------------------
# Comma-separated extra domains permitted as auth redirect targets.
# OXY_ALLOWED_REDIRECT_DOMAINS=app.oxy.so,console.oxy.so


# -----------------------------------------------------------------------------
# Debug toggles  (DEVELOPMENT ONLY — never set in production)
# -----------------------------------------------------------------------------
# When 'true', includes the recovery code in sign-in/recovery responses.
# Leaks sensitive data; keep unset everywhere except local debugging.
# OXY_DEV_RECOVERY_DEBUG=false


# -----------------------------------------------------------------------------
# AI auto-labeling  ([optional]; disabled unless enabled)
# -----------------------------------------------------------------------------
# AI_LABELING_ENABLED=false
# AI_LABELING_MODEL=
# AI_LABELING_TIMEOUT=
# [SECRET] API key for the Alia AI service
# ALIA_API_KEY=


# =============================================================================
# EMAIL SERVER  (SMTP inbound + outbound)
# Only relevant when running the email worker. Most are [optional]/[SECRET].
# =============================================================================

# Master switch — starts the embedded SMTP inbound server when true.
# SMTP_ENABLED=false

# Inbound SMTP listener
# SMTP_HOST=0.0.0.0
# SMTP_PORT=25
# SMTP_STARTTLS_PORT=587
# SMTP_BANNER=Oxy Mail
# SMTP_MAX_MESSAGE_SIZE=26214400
# TLS material for STARTTLS (PEM contents or paths, depending on deploy)
# [SECRET]
# SMTP_TLS_KEY=
# SMTP_TLS_CERT=

# Outbound relay (smarthost) — if unset, sends direct via MX
# SMTP_RELAY_HOST=
# SMTP_RELAY_PORT=587
# SMTP_RELAY_USER=
# [SECRET]
# SMTP_RELAY_PASS=

# Primary email domain for sent mail / address validation
# EMAIL_DOMAIN=oxy.so
# Encrypt stored message bodies at rest (true/false)
# EMAIL_ENCRYPT_AT_REST=false
# [SECRET] shared secret guarding POST /email/inbound (Cloudflare Email Routing webhook)
# EMAIL_INBOUND_WEBHOOK_SECRET=

# DKIM signing
# DKIM_SELECTOR=default
# [SECRET] DKIM private key (PEM)
# DKIM_PRIVATE_KEY=

# Dedicated S3 bucket for raw email storage (falls back to AWS_* if unset)
# EMAIL_S3_BUCKET=
# EMAIL_S3_REGION=
# EMAIL_S3_ENDPOINT=
# [SECRET]
# EMAIL_S3_ACCESS_KEY_ID=
# [SECRET]
# EMAIL_S3_SECRET_ACCESS_KEY=

# Spam filtering (rspamd)
# SPAM_FILTER_ENABLED=false
# RSPAMD_URL=http://localhost:11333
# SPAM_THRESHOLD=5
# SPAM_REJECT_THRESHOLD=15
